# Database
DATABASE_URL="postgresql://ngowamix:ngowamix_secret@localhost:5432/ngowamix?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# App
API_PORT=3001
CORS_ORIGIN="http://localhost:3000"

# Frontend — URL de l'API backend (NestJS)
NEXT_PUBLIC_API_URL="http://localhost:3001"

# Upload
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE=52428800

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# Email — Resend HTTP API (recommandé, fonctionne sur Render free tier)
RESEND_API_KEY=""
RESEND_FROM="Ngowamix <noreply@ngowamix.com>"

# Email — SMTP classique (fallback, local seulement : Render bloque les ports SMTP)
SMTP_HOST=""
SMTP_PORT=465
SMTP_USER="resend"
SMTP_PASS=""
SMTP_FROM="Ngowamix <noreply@ngowamix.com>"
